{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Whisperline",
  "version": "0.1.0",
  "identifier": "com.aidxn.whisperline",
  "build": {
    "frontendDist": "../public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Whisperline",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$RESOURCE/*", "$APPDATA/*", "$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "nsis", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Drag-drop audio + video into transcripts",
    "longDescription": "Whisperline turns audio and video files into clean, diarised transcripts with word-level timestamps. Cross-platform desktop app — drag in, transcribe, export.",
    "copyright": "© 2026 Aidxn Design",
    "publisher": "Aidxn Design",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "exceptionDomain": "api.assemblyai.com"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libssl3"]
      }
    }
  }
}
